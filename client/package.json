{
  "name": "@aether/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tsc && tauri build",
    "build:app": "tsc && tauri build --bundles none",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aether/types": "workspace:*",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1",
    "fuse.js": "^7",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "eslint": "^9",
    "jsdom": "^25",
    "playwright": "^1",
    "postcss": "^8",
    "prettier": "^3",
    "typescript": "^5.5",
    "vite": "^6",
    "vitest": "^2"
  }
}
