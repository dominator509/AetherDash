root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{rs,toml}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,yaml,yml,css,html}]
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
