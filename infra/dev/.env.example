# ================================================================
# AETHER Terminal — Dev Environment Variables
# Copy to .env.dev (gitignored) and fill in secrets.
# All variables with defaults shown; secrets marked with (secret).
# DO NOT commit real secrets. This file IS committed.
# ================================================================

# ── Core Database ──────────────────────────────────────────────
DATABASE_URL=postgres://aether:aether@localhost:5432/aether

# ── ClickHouse ─────────────────────────────────────────────────
AETHER_CLICKHOUSE__URL=http://localhost:8123
AETHER_CLICKHOUSE__DATABASE=aether
AETHER_CLICKHOUSE__USER=aether
AETHER_CLICKHOUSE__PASSWORD=aether

# ── Redis ──────────────────────────────────────────────────────
AETHER_REDIS__URL=redis://localhost:6379

# ── Qdrant ─────────────────────────────────────────────────────
AETHER_QDRANT__URL=http://localhost:6333

# ── Redpanda / Kafka ───────────────────────────────────────────
AETHER_KAFKA__BROKERS=localhost:9092

# ── MinIO ──────────────────────────────────────────────────────
AETHER_MINIO__ENDPOINT=http://localhost:9000
AETHER_MINIO__ACCESS_KEY=minioadmin
AETHER_MINIO__SECRET_KEY=minioadmin

# ── Kuzu Graph ─────────────────────────────────────────────────
AETHER_KUZU__PATH=./data/kuzu

# ── Environment ────────────────────────────────────────────────
AETHER_ENV=dev
AETHER_LOG__LEVEL=info
AETHER_LOG__FORMAT=pretty

# ── Service Binds ──────────────────────────────────────────────
AETHER_GATEWAY__BIND=0.0.0.0:8080
AETHER_BRAIN__BIND=127.0.0.1:8000
AETHER_LLM__BIND=127.0.0.1:8001
AETHER_ALERTS__BIND=127.0.0.1:8002
AETHER_INBOX__BIND=127.0.0.1:8003
AETHER_ROUTER__BIND=127.0.0.1:50051
AETHER_RISK__BIND=127.0.0.1:50052
AETHER_GUARDIAN__BIND=127.0.0.1:50053

# ── LLM API Keys (secret) ──────────────────────────────────────
AETHER_LLM__ANTHROPIC_API_KEY=
AETHER_LLM__DEEPSEEK_API_KEY=
AETHER_LLM__XAI_API_KEY=
AETHER_LLM__OPENAI_API_KEY=
AETHER_LLM__LOCAL_ENDPOINT=

# ── Venue Credentials (secret) ─────────────────────────────────
AETHER_VENUE__KALSHI_API_KEY_ID=
AETHER_VENUE__KALSHI_PRIVATE_KEY_PATH=
AETHER_VENUE__ALPACA_KEY_ID=
AETHER_VENUE__ALPACA_SECRET=
AETHER_VENUE__POLYGON_RPC_URL=

# ── Comms Credentials (secret) ─────────────────────────────────
AETHER_COMMS__TELEGRAM_BOT_TOKEN=
AETHER_COMMS__DISCORD_BOT_TOKEN=
AETHER_COMMS__SLACK_BOT_TOKEN=

# ── Execution Safety ───────────────────────────────────────────
# AETHER_EXECUTION__LIVE_ENABLED is operator-configured out-of-band only (ADR-0007).
# It must NOT appear in templates, examples, or agent output.
AETHER_EXECUTION__PAPER=true
